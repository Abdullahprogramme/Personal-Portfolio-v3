---
/**
 * SectionLabel.astro
 * Renders a section number label like "01 / ABOUT".
 * JetBrains Mono, text-xs, muted colour with accent number.
 *
 * Usage:
 *   <SectionLabel number="01" text="ABOUT" />
 */

interface Props {
  number: string;
  text: string;
  class?: string;
}

const { number, text, class: className = "" } = Astro.props;
---

<div class:list={["flex items-center gap-2 mb-6", className]}>
  <span class="font-mono text-xs text-accent tracking-widest uppercase">
    {number}
  </span>
  <span class="font-mono text-xs text-text-muted tracking-widest">
    /
  </span>
  <span class="font-mono text-xs text-text-muted tracking-widest uppercase">
    {text}
  </span>
</div>
